<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitlePopup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_add_aviso"
        android:textColor="@color/unibus_blue"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnClosePopup"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/unibus_blue"
        android:contentDescription="Fechar" />

    <EditText
        android:id="@+id/etAvisoInput"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input_bordered"
        android:gravity="top"
        android:hint="@string/hint_digite_aviso"
        android:padding="16dp"
        android:textColor="@color/unibus_blue"
        app:layout_constraintTop_toBottomOf="@id/tvTitlePopup" />

    <Button
        android:id="@+id/btnEnviarAviso"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/unibus_blue"
        android:text="@string/btn_enviar"
        android:textColor="@color/white"
        app:cornerRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etAvisoInput" />

</androidx.constraintlayout.widget.ConstraintLayout>