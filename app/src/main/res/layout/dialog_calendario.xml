<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    tools:showIn="@layout/activity_estatisticas">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Escolha a data desejada:"
            android:textColor="@color/unibus_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/unibus_blue"
            android:contentDescription="@null" />

        <!-- Header do Mês -->
        <LinearLayout
            android:id="@+id/llMonthHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDialogTitle">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/unibus_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:text="Abril de 2025"
                android:textColor="@color/unibus_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="@color/unibus_blue" />
        </LinearLayout>

        <!-- Header Dias da Semana -->
        <LinearLayout
            android:id="@+id/llDaysHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/llMonthHeader">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="SUN" android:textColor="#B3B3B3" android:textSize="10sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="MON" android:textColor="#B3B3B3" android:textSize="10sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="TUE" android:textColor="#B3B3B3" android:textSize="10sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="WED" android:textColor="#B3B3B3" android:textSize="10sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="THU" android:textColor="#B3B3B3" android:textSize="10sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="FRI" android:textColor="#B3B3B3" android:textSize="10sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="SAT" android:textColor="#B3B3B3" android:textSize="10sp" />
        </LinearLayout>

        <!-- Grid de Dias (Simulado) -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="7"
            app:layout_constraintTop_toBottomOf="@id/llDaysHeader">

            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="1" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="2" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="3" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="4" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="5" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="6" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="7" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="8" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="9" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="10" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="11" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="12" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="13" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="14" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="15" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="16" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="17" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="18" android:textColor="@color/text_gray" />

            <!-- Dia Selecionado (19) -->
            <FrameLayout android:layout_columnWeight="1" android:layout_gravity="center">
                <View android:layout_width="32dp" android:layout_height="32dp" android:layout_gravity="center" android:background="@drawable/bg_white_qr" android:backgroundTint="@color/unibus_blue" android:alpha="0.2" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="10dp" android:text="19" android:textColor="@color/unibus_blue" android:textStyle="bold" />
            </FrameLayout>

            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="20" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="21" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="22" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="23" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="24" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="25" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="26" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="27" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="28" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="29" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="30" android:textColor="@color/text_gray" />
            <TextView android:layout_columnWeight="1" android:gravity="center" android:padding="10dp" android:text="31" android:textColor="@color/text_gray" />
        </GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
