<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_beige">

    <!-- Header Logo -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="20dp"
        android:adjustViewBounds="true"
        android:src="@drawable/logo_unibus_texto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="@string/unibus_logo" />

    <!-- Card Admin (Azul) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvAdminHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/unibus_blue"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/ivLogo">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Avatar Circular -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="85dp"
                android:layout_height="85dp"
                android:background="@color/white"
                android:padding="3dp"
                android:src="@drawable/chatgpt_image_11_de_mai__de_2025__15_39_41_removebg_preview_1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/admin_greeting"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/tvAdminId"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivAvatar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvAdminId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2121054"
                android:textColor="#B3FFFFFF"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvGreeting"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Grid de Estatísticas (Cards Cinzas) -->
    <GridLayout
        android:id="@+id/glStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:columnCount="2"
        android:rowCount="2"
        app:layout_constraintTop_toBottomOf="@id/cvAdminHeader">

        <!-- Card Alunos -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvActiveStudents"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#C4C0B3"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <RelativeLayout android:padding="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/lblStudents" android:text="@string/label_active_students" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:text="40" android:textColor="@color/text_gray" android:textSize="32sp" android:textStyle="bold" android:layout_alignParentEnd="true" android:layout_below="@id/lblStudents" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Motoristas -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvDriversCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#C4C0B3"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <RelativeLayout android:padding="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/lblDrivers" android:text="@string/label_drivers" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:text="0" android:textColor="@color/text_gray" android:textSize="32sp" android:textStyle="bold" android:layout_alignParentEnd="true" android:layout_below="@id/lblDrivers" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Viagens -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvTripsCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#C4C0B3"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <RelativeLayout android:padding="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/lblTrips" android:text="@string/label_trips" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:text="3" android:textColor="@color/text_gray" android:textSize="32sp" android:textStyle="bold" android:layout_alignParentEnd="true" android:layout_below="@id/lblTrips" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Chamados -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvTicketsCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#C4C0B3"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <RelativeLayout android:padding="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/lblTickets" android:text="@string/label_tickets" android:textColor="@color/text_gray" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:text="4" android:textColor="@color/text_gray" android:textSize="32sp" android:textStyle="bold" android:layout_alignParentEnd="true" android:layout_below="@id/lblTickets" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </GridLayout>

    <!-- Botões de Ação -->
    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/glStats">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnGeneralStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <TextView android:padding="14dp" android:gravity="center" android:text="@string/btn_general_stats" android:textColor="@color/unibus_blue" android:textSize="18sp" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnManageRoutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <TextView android:padding="14dp" android:gravity="center" android:text="@string/btn_manage_routes" android:textColor="@color/unibus_blue" android:textSize="18sp" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnManageUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <TextView android:padding="14dp" android:gravity="center" android:text="@string/btn_manage_users" android:textColor="@color/unibus_blue" android:textSize="18sp" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <TextView android:padding="14dp" android:gravity="center" android:text="@string/btn_reports" android:textColor="@color/unibus_blue" android:textSize="18sp" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Bottom Nav -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_home" app:tint="@color/unibus_blue" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nav_home" android:textColor="@color/unibus_blue" android:textSize="12sp"/>
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDD"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu" app:tint="@color/unibus_blue" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nav_preferences" android:textColor="@color/unibus_blue" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
