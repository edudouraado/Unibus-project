<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_beige">

    <!-- Header: Ícone de Voltar e Logo -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/back_button_desc"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/unibus_blue" />

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/logo_unibus_texto"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@string/unibus_logo" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Card de Título (Estatísticas) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@color/unibus_blue"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <View
                android:id="@+id/vLine"
                android:layout_width="2dp"
                android:layout_height="0dp"
                android:background="@color/white"
                app:layout_constraintBottom_toBottomOf="@+id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvTitle" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/title_statistics"
                android:textColor="@color/white"
                android:textSize="38sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/vLine"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Barra de Período (Cinza) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvPeriod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#C4C0B3"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/cvTitle">

        <LinearLayout
            android:id="@+id/btnOpenCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_period"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_qr"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/ic_menu_my_calendar" app:tint="#B3B3B3" />
                <TextView android:id="@+id/tvStartDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="01/04/2025" android:textColor="#B3B3B3" android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_white_qr"
                android:backgroundTint="@color/white"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@android:drawable/ic_menu_my_calendar" app:tint="#B3B3B3" />
                <TextView android:id="@+id/tvEndDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="19/04/2025" android:textColor="#B3B3B3" android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card de Top Rotas (Branco) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvTopRoutes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cvPeriod">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top rotas:"
                android:textColor="#4D4D4D"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="end"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Parangaba" android:textColor="#A6A295" android:textSize="18sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" - 120 usos" android:textColor="@color/unibus_blue" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="end"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ant. Bezerra / Papicu" android:textColor="#A6A295" android:textSize="18sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" - 180 usos" android:textColor="@color/unibus_blue" android:textSize="18sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Gráfico de Uso por Horário -->
    <TextView
        android:id="@+id/tvGraphLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Uso por horário:"
        android:textColor="@color/unibus_blue"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cvTopRoutes" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clGraph"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@+id/navBar"
        app:layout_constraintTop_toBottomOf="@id/tvGraphLabel">

        <!-- Área Interna do Gráfico com Grade -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/graphArea"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="45dp"
            android:layout_marginBottom="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Linhas de Grade Horizontais -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDD" app:layout_constraintTop_toTopOf="parent" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDD" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintVertical_bias="0.2" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDD" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintVertical_bias="0.4" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDD" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintVertical_bias="0.6" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DDD" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintVertical_bias="0.8" />

            <!-- Linhas de Grade Verticais -->
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDD" app:layout_constraintStart_toStartOf="parent" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDD" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHorizontal_bias="0.33" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDD" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintHorizontal_bias="0.66" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDD" app:layout_constraintEnd_toEndOf="parent" />

            <!-- A Linha do Gráfico (Diagonal conectada aos eixos) -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/ic_graph_line"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Eixos (Bordas) -->
        <View android:id="@+id/axisY" android:layout_width="2dp" android:layout_height="0dp" android:background="#A6A295" app:layout_constraintBottom_toBottomOf="@id/graphArea" app:layout_constraintStart_toStartOf="@id/graphArea" app:layout_constraintTop_toTopOf="@id/graphArea" />
        <View android:id="@+id/axisX" android:layout_width="0dp" android:layout_height="2dp" android:background="#A6A295" app:layout_constraintBottom_toBottomOf="@id/graphArea" app:layout_constraintEnd_toEndOf="@id/graphArea" app:layout_constraintStart_toStartOf="@id/graphArea" />

        <!-- Legendas Y (Alinhadas às linhas de grade) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="160\nalunos" android:textSize="10sp" android:textColor="#A6A295" android:gravity="end" app:layout_constraintEnd_toStartOf="@id/axisY" app:layout_constraintTop_toTopOf="@id/graphArea" app:layout_constraintBottom_toTopOf="@id/graphArea" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="80\nalunos" android:textSize="10sp" android:textColor="#A6A295" android:gravity="end" app:layout_constraintEnd_toStartOf="@id/axisY" app:layout_constraintTop_toTopOf="@id/graphArea" app:layout_constraintBottom_toBottomOf="@id/graphArea" app:layout_constraintVertical_bias="0.2" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40\nalunos" android:textSize="10sp" android:textColor="#A6A295" android:gravity="end" app:layout_constraintEnd_toStartOf="@id/axisY" app:layout_constraintTop_toTopOf="@id/graphArea" app:layout_constraintBottom_toBottomOf="@id/graphArea" app:layout_constraintVertical_bias="0.4" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20\nalunos" android:textSize="10sp" android:textColor="#A6A295" android:gravity="end" app:layout_constraintEnd_toStartOf="@id/axisY" app:layout_constraintTop_toTopOf="@id/graphArea" app:layout_constraintBottom_toBottomOf="@id/graphArea" app:layout_constraintVertical_bias="0.6" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10\nalunos" android:textSize="10sp" android:textColor="#A6A295" android:gravity="end" app:layout_constraintEnd_toStartOf="@id/axisY" app:layout_constraintTop_toTopOf="@id/graphArea" app:layout_constraintBottom_toBottomOf="@id/graphArea" app:layout_constraintVertical_bias="0.8" android:layout_marginEnd="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="10sp" android:textColor="#A6A295" app:layout_constraintEnd_toStartOf="@id/axisY" app:layout_constraintTop_toTopOf="@id/axisX" app:layout_constraintBottom_toBottomOf="@id/axisX" android:layout_marginEnd="6dp" />

        <!-- Legendas X (Alinhadas às colunas) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1º de\nabril" android:textSize="10sp" android:textColor="#A6A295" android:gravity="center" app:layout_constraintTop_toBottomOf="@id/axisX" app:layout_constraintStart_toStartOf="@id/axisX" android:layout_marginTop="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 de\nabril" android:textSize="10sp" android:textColor="#A6A295" android:gravity="center" app:layout_constraintTop_toBottomOf="@id/axisX" app:layout_constraintStart_toStartOf="@id/axisX" app:layout_constraintEnd_toEndOf="@id/axisX" app:layout_constraintHorizontal_bias="0.33" android:layout_marginTop="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10 de\nabril" android:textSize="10sp" android:textColor="#A6A295" android:gravity="center" app:layout_constraintTop_toBottomOf="@id/axisX" app:layout_constraintStart_toStartOf="@id/axisX" app:layout_constraintEnd_toEndOf="@id/axisX" app:layout_constraintHorizontal_bias="0.66" android:layout_marginTop="6dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12 de\nabril" android:textSize="10sp" android:textColor="#A6A295" android:gravity="center" app:layout_constraintTop_toBottomOf="@id/axisX" app:layout_constraintEnd_toEndOf="@id/axisX" android:layout_marginTop="6dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Nav Bar -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingVertical="12dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_home" app:tint="@color/unibus_blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nav_home" android:textColor="@color/unibus_blue" android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#DDD"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_menu" app:tint="@color/unibus_blue" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nav_preferences" android:textColor="@color/unibus_blue" android:textSize="12sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
